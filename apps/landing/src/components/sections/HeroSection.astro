---
// HeroSection component — zero JS, fully static
---
<section class="relative min-h-[100dvh] flex items-center justify-center pt-24 px-4 overflow-hidden">
  <!-- Ambient glow orbs -->
  <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[400px] h-[400px] md:w-[600px] md:h-[600px] bg-[#00E5FF] rounded-full blur-[120px] md:blur-[150px] opacity-20 dark:opacity-15 pointer-events-none"></div>
  <div class="absolute top-1/4 right-1/4 w-[300px] h-[300px] md:w-[400px] md:h-[400px] bg-[#8A2BE2] rounded-full blur-[100px] md:blur-[120px] opacity-20 dark:opacity-10 pointer-events-none"></div>

  <div class="relative z-10 max-w-4xl mx-auto text-center flex flex-col items-center gap-6 md:gap-8 mt-[-8vh]">
    <!-- Status pill -->
    <div class="inline-flex items-center gap-3 bg-white dark:bg-[#252634] rounded-full px-4 py-2 border border-slate-200 dark:border-white/5 shadow-sm dark:shadow-none">
      <span class="w-2 h-2 rounded-full bg-purple-500 dark:bg-[#8A2BE2] animate-pulse shadow-[0_0_8px_#8A2BE2]"></span>
      <span class="font-mono text-[10px] md:text-xs uppercase tracking-[0.15em] text-purple-600 dark:text-[#8A2BE2]">[ SYSTEM: ONLINE ]</span>
    </div>

    <!-- Heading -->
    <h1 class="text-5xl sm:text-6xl md:text-8xl font-bold tracking-tighter text-slate-900 dark:text-white leading-none">
      Enter the <span class="text-transparent bg-clip-text bg-gradient-to-r from-[#8A2BE2] to-[#00E5FF]">Forge.</span>
    </h1>

    <!-- Subheadline -->
    <p class="text-base sm:text-lg md:text-xl text-slate-600 dark:text-[#A0A0B0] max-w-2xl leading-relaxed px-4">
      The digital nervous system for the College of Computer Studies. Stop losing progress in fragmented chats. Build a visible record of your growth, one challenge at a time.
    </p>

    <!-- CTAs -->
    <div class="flex flex-col sm:flex-row w-full sm:w-auto gap-4 mt-6 px-4 sm:px-0">
      <button class="bg-purple-600 dark:bg-[#8A2BE2] text-white font-bold rounded-full px-8 py-4 transition-all duration-300 hover:scale-[1.03] shadow-md dark:shadow-none hover:shadow-[0_0_25px_rgba(138,43,226,0.4)] w-full sm:w-auto flex items-center justify-center gap-2">
        Authenticate // Enter
      </button>
      <button class="bg-transparent border border-slate-300 dark:border-[#A0A0B0] text-slate-700 dark:text-[#A0A0B0] font-medium rounded-full px-8 py-4 transition-all duration-300 hover:border-slate-900 dark:hover:border-white hover:text-slate-900 dark:hover:text-white hover:bg-slate-100 dark:hover:bg-white/5 w-full sm:w-auto mt-2 sm:mt-0 flex items-center justify-center">
        View Architecture
      </button>
    </div>
  </div>

  <!-- Scroll indicator -->
  <div class="absolute bottom-8 left-1/2 -translate-x-1/2 flex flex-col items-center gap-2 text-slate-400 dark:text-[#5C5C70] animate-bounce">
    <span class="font-mono text-[10px] uppercase tracking-widest">Scroll</span>
    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
      <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 14l-7 7m0 0l-7-7m7 7V3" />
    </svg>
  </div>
</section>
