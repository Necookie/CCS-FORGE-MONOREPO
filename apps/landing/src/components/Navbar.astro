---
// Navbar Component
---
<header class="w-full fixed top-0 bg-white/80 dark:bg-[#252634]/80 backdrop-blur-md border-b border-slate-200 dark:border-white/5 p-4 z-50 transition-all duration-300">
  <nav class="max-w-7xl mx-auto flex justify-between items-center px-4 md:px-8">
    <a href="/" aria-label="Go to home" class="flex items-center gap-3 group cursor-pointer">
      <div class="w-9 h-9 rounded-xl overflow-hidden group-hover:shadow-[0_0_15px_rgba(138,43,226,0.4)] transition-all duration-300 ring-2 ring-transparent group-hover:ring-purple-500/50 shrink-0 bg-slate-100 dark:bg-[#1A1A24]">
        <img
          src="https://res.cloudinary.com/dd6gz4moa/image/upload/v1776408761/Logo_ijocyn.jpg"
          alt="Code Bearers Logo"
          class="w-full h-full object-cover group-hover:scale-105 transition-transform duration-300"
          loading="eager"
        />
      </div>
      <span class="text-slate-900 dark:text-white font-bold text-xl tracking-wide group-hover:text-purple-600 dark:group-hover:text-[#8A2BE2] transition-colors">Forge</span>
    </a>
    <div class="hidden md:flex gap-8 text-sm font-medium text-slate-600 dark:text-[#A0A0B0]">
      <a href="/#genesis" class="hover:text-slate-900 dark:hover:text-white transition-colors">Origins</a>
      <a href="/archive" class="text-purple-600 dark:text-[#8A2BE2] hover:text-purple-700 dark:hover:text-white transition-colors glow-link">The Archive</a>
      <a href="/#arena" class="hover:text-slate-900 dark:hover:text-white transition-colors">The Arena</a>
      <a href="/#foundry" class="hover:text-slate-900 dark:hover:text-white transition-colors">Foundry</a>
    </div>
    <div class="flex items-center gap-2 md:gap-4">
      <button id="theme-toggle" aria-label="Toggle theme" class="p-2 rounded-xl border border-slate-200 dark:border-white/5 text-slate-600 dark:text-[#A0A0B0] hover:bg-slate-100 dark:hover:bg-white/5 transition-all">
        <!-- Sun icon (shown in dark mode) -->
        <svg class="w-5 h-5 hidden dark:block" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 3v1m0 16v1m9-9h-1M4 12H3m15.364 6.364l-.707-.707M6.343 6.343l-.707-.707m12.728 0l-.707.707M6.343 17.657l-.707.707M16 12a4 4 0 11-8 0 4 4 0 018 0z" />
        </svg>
        <!-- Moon icon (shown in light mode) -->
        <svg class="w-5 h-5 block dark:hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M20.354 15.354A9 9 0 018.646 3.646 9.003 9.003 0 0012 21a9.003 9.003 0 008.354-5.646z" />
        </svg>
      </button>
      <a href="/login" class="inline-flex items-center justify-center bg-transparent border border-slate-300 dark:border-white/5 text-slate-800 dark:text-white rounded-xl px-5 py-2 text-sm font-medium transition-all hover:border-[#8A2BE2] hover:text-[#8A2BE2] dark:hover:shadow-[0_0_10px_rgba(138,43,226,0.2)]">
        Log In
      </a>
    </div>
  </nav>
</header>
