---
import '../global.css';
import { Button } from '@forge/ui';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Forge WebHub</title>
  </head>
  <body class="bg-[#1A1A24] text-white min-h-screen flex flex-col items-center justify-center">
    <header class="w-full fixed top-0 bg-[#252634]/80 backdrop-blur-md border-b border-white/5 p-4 z-50">
      <nav class="max-w-7xl mx-auto flex justify-between items-center">
        <h1 class="text-[#00E5FF] font-bold text-xl tracking-wider">CCS FORGE</h1>
        <Button client:load>Login</Button>
      </nav>
    </header>
    
    <main class="text-center px-4 pt-32">
      <h2 class="text-5xl font-extrabold mb-6">Build the Future</h2>
      <p class="text-xl text-gray-400 mb-10 max-w-2xl mx-auto">
        Static Content Hub. Experience the next generation of building things with blazing fast static generation.
      </p>
      <Button client:load className="text-lg px-8 py-4">Get Started</Button>
    </main>
  </body>
</html>