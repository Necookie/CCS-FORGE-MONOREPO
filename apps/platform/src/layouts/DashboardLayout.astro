---
// apps/platform/src/layouts/DashboardLayout.astro
import '../../src/global.css';
import BaseHead from '../components/BaseHead.astro';

interface Props {
  title: string;
}

const { title } = Astro.props;
---

<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <BaseHead />
    <title>{title} // CCS Forge</title>
  </head>
  <body class="bg-[#1A1A24] text-white min-h-screen flex overflow-hidden selection:bg-purple-500/30">
    
    <!-- Navigation Sidebar -->
    <aside class="w-64 border-r border-white/5 bg-[#1F1F2B] hidden lg:flex flex-col shrink-0">
      <div class="p-6 border-b border-white/5 flex items-center gap-3">
        <div class="w-8 h-8 rounded-lg overflow-hidden ring-1 ring-purple-500/30">
             <img src="https://res.cloudinary.com/dd6gz4moa/image/upload/v1776408761/Logo_ijocyn.jpg" alt="Logo" class="w-full h-full object-cover" />
        </div>
        <span class="font-bold tracking-tight text-lg">FORGE <span class="text-purple-500">OS</span></span>
      </div>

      <nav class="flex-grow p-4 mt-4 flex flex-col gap-2">
        <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-xl bg-purple-500/10 text-purple-400 border border-purple-500/20 shadow-[0_0_15px_rgba(138,43,226,0.1)] transition-all">
          <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2V6zM14 6a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2V6zM4 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2H6a2 2 0 01-2-2v-2zM14 16a2 2 0 012-2h2a2 2 0 012 2v2a2 2 0 01-2 2h-2a2 2 0 01-2-2v-2z" /></svg>
          <span class="font-medium text-sm">Dashboard</span>
        </a>
        <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition-all group">
          <svg class="w-5 h-5 group-hover:text-cyan-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10" /></svg>
          <span class="font-medium text-sm">Missions</span>
        </a>
        <a href="#" class="flex items-center gap-3 px-4 py-3 rounded-xl text-slate-400 hover:text-white hover:bg-white/5 transition-all group">
          <svg class="w-5 h-5 group-hover:text-cyan-500 transition-colors" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 3v4M3 5h4M6 17v4m-2-2h4m5-16l2.286 6.857L21 12l-5.714 2.143L13 21l-2.286-6.857L5 12l5.714-2.143L13 3z" /></svg>
          <span class="font-medium text-sm">The Armory</span>
        </a>
      </nav>

      <div class="mt-auto p-4 border-t border-white/5">
        <div class="flex items-center gap-3 p-2 rounded-2xl bg-white/5 border border-white/5">
           <div class="w-10 h-10 rounded-full bg-slate-700 border border-white/10 overflow-hidden">
             <img src="https://api.dicebear.com/9.x/avataaars/svg?seed=Felix" alt="Avatar" />
           </div>
           <div class="flex flex-col overflow-hidden">
              <span class="text-xs font-bold truncate">OPERATIVE_FELIX</span>
              <span class="text-[10px] text-slate-500 font-mono truncate">ID: cb-2490</span>
           </div>
        </div>
      </div>
    </aside>

    <!-- Main Content -->
    <main class="flex-grow flex flex-col min-w-0 overflow-y-auto bg-gradient-to-br from-[#1A1A24] via-[#1A1A24] to-[#1e1e2d]">
      
      <!-- Top Header -->
      <header class="h-20 border-b border-white/5 shrink-0 bg-[#1A1A24]/50 backdrop-blur-xl flex items-center justify-between px-8 sticky top-0 z-30">
        <h1 class="font-bold text-xl tracking-tight hidden sm:block">{title}</h1>
        <div class="flex items-center gap-4">
           <div class="hidden md:flex flex-col items-end mr-4">
              <span class="text-[10px] uppercase font-bold text-slate-500 tracking-[0.2em] leading-none mb-1">System Status</span>
              <span class="text-[10px] font-mono text-emerald-500 flex items-center gap-1.5 uppercase tracking-widest">
                <span class="w-1.5 h-1.5 rounded-full bg-emerald-500 animate-pulse"></span>
                Secure Protocol Active
              </span>
           </div>
           <button class="w-10 h-10 rounded-xl bg-white/5 border border-white/5 hover:bg-white/10 flex items-center justify-center transition-all">
             <svg class="w-5 h-5 text-slate-400" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
           </button>
        </div>
      </header>

      <!-- Dashboard View -->
      <div class="p-8 max-w-7xl w-full mx-auto">
        <slot />
      </div>

    </main>

  </body>
</html>
