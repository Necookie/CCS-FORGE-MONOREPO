---
// apps/platform/src/layouts/PlatformLayout.astro
import '../global.css';

interface Props {
  title: string;
  currentPath?: string;
}

const { title, currentPath = '/' } = Astro.props;

const NAV_ITEMS = [
  { path: '/', label: 'Explore' },
  { path: '/quests', label: 'Quests' },
  { path: '/community', label: 'Community' },
  { path: '/armory', label: 'The Armory' }
];

---
<!DOCTYPE html>
<html lang="en" class="scroll-smooth">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title} // CCS Forge</title>
    <!-- We bring in Google Fonts matching brand.md -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600;700&family=Outfit:wght@300;400;500;600;700&display=swap" rel="stylesheet">
  </head>
  <body class="bg-slate-50 dark:bg-[#1A1A24] text-slate-900 dark:text-white min-h-screen flex flex-col selection:bg-purple-500/30 font-sans antialiased">
    
    <!-- Top Navigation Bar -->
    <header class="w-full fixed top-0 bg-white/80 dark:bg-white dark:bg-[#252634]/90 backdrop-blur-md border-b border-slate-200 dark:border-white/5 z-50">
      <div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 h-16 flex items-center justify-between">
         
         <!-- Logo & Primary Links -->
         <div class="flex items-center gap-8">
            <a href="/" class="flex items-center gap-3 group">
               <div class="w-9 h-9 rounded-xl overflow-hidden ring-1 ring-purple-500/30 group-hover:ring-purple-400 transition-all shadow-[0_0_10px_rgba(138,43,226,0.2)]">
                 <img src="https://res.cloudinary.com/dd6gz4moa/image/upload/v1776408761/Logo_ijocyn.jpg" alt="Code Bearers Logo" class="w-full h-full object-cover group-hover:scale-105 transition-transform" />
               </div>
               <span class="font-bold tracking-tight text-lg leading-none hidden sm:block">FORGE</span>
            </a>

            <nav class="hidden md:flex items-center gap-1">
               {NAV_ITEMS.map((item) => {
                 const isActive = currentPath === item.path;
                 return (
                   <a 
                     href={item.path} 
                     class={`px-4 py-2 rounded-xl text-sm font-medium transition-all ${
                       isActive 
                         ? 'text-slate-900 dark:text-white bg-slate-100 dark:bg-white/5' 
                         : 'text-slate-600 dark:text-[#A0A0B0] hover:text-slate-900 dark:text-white hover:bg-slate-100 dark:bg-white/5'
                     }`}
                   >
                     {item.label}
                   </a>
                 );
               })}
            </nav>
         </div>

         <!-- Right Utilities (Search, Profile) -->
         <div class="flex items-center gap-4">
            
            <!-- Global Search Placeholder -->
            <div class="hidden lg:flex items-center gap-2 px-3 py-1.5 bg-slate-50 dark:bg-[#1A1A24] border border-slate-200 dark:border-white/5 rounded-xl text-slate-500 text-sm w-48 focus-within:border-purple-500/50 transition-colors">
               <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" /></svg>
               <input type="text" placeholder="Search quests..." class="bg-transparent border-none outline-none w-full text-slate-900 dark:text-white placeholder-slate-600" />
            </div>

            <!-- Notification Bell -->
            <button class="relative p-2 text-slate-600 dark:text-[#A0A0B0] hover:text-slate-900 dark:text-white transition-colors rounded-xl hover:bg-slate-100 dark:bg-white/5">
               <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" /></svg>
               <span class="absolute top-1.5 right-1.5 w-2 h-2 bg-purple-500 rounded-full ring-2 ring-[#252634]"></span>
            </button>

            <!-- User Avatar Dropdown -->
            <button class="flex items-center gap-2 pl-2 border-l border-slate-300 dark:border-white/10 group">
               <div class="flex flex-col items-end hidden sm:flex">
                  <span class="text-xs font-bold text-slate-900 dark:text-white group-hover:text-purple-400 transition-colors leading-tight">Felix</span>
                  <span class="text-[9px] text-cyan-400 font-mono flex items-center gap-1 uppercase tracking-widest"><span class="w-1.5 h-1.5 bg-cyan-400 rounded-full animate-pulse"></span> Lv. 42</span>
               </div>
               <div class="w-8 h-8 rounded-xl bg-slate-800 border border-slate-300 dark:border-white/10 overflow-hidden shrink-0 group-hover:border-purple-500/50 transition-colors">
                  <img src="https://api.dicebear.com/9.x/avataaars/svg?seed=Felix" alt="Avatar" class="w-full h-full object-contain" />
               </div>
            </button>

         </div>
      </div>
    </header>

    <!-- Main Content Container -->
    <main class="flex-grow pt-24 pb-16 w-full max-w-7xl mx-auto px-4 sm:px-6 lg:px-8">
      <slot />
    </main>

  </body>
</html>
