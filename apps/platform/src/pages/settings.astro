---
import PlatformLayout from '../layouts/PlatformLayout.astro';

const accountSecurity = [
  { title: 'Password Management', detail: 'Change password and expose strength indicator states.' },
  { title: 'Two-Factor Authentication', detail: 'Enable app-based or email-based verification codes.' },
  { title: 'Email Management', detail: 'Manage primary institutional email and secondary recovery email.' },
  { title: 'Authorized Devices', detail: 'Review active sessions and provide a log out of all devices action.' },
  { title: 'Account Status', detail: 'Deactivate temporarily or permanently delete the account.' },
];

const privacyData = [
  { label: 'Profile Visibility', value: 'Institutional Only' },
  { label: 'Searchability', value: 'Allow Internal Discovery Only' },
  { label: 'Data Export', value: 'JSON / PDF Archive' },
  { label: 'Ad / Activity Tracking', value: 'Opt-out Ready' },
  { label: 'Blocked List', value: '03 Managed Users' },
];

const notifications = [
  { title: 'Academic Alerts', detail: 'Assignment deadlines, grade postings, class cancellations.' },
  { title: 'Social Interactions', detail: 'New followers, post likes, mentions, direct messages.' },
  { title: 'Delivery Methods', detail: 'Push notifications, email digests, in-app badges.' },
  { title: 'Quiet Hours / Do Not Disturb', detail: 'Scheduled silence periods for non-emergency alerts.' },
];

const appearance = [
  { label: 'Theme Settings', value: 'Light / Deep Dark / Cinematic / System Default' },
  { label: 'Accent Color', value: 'Brand Purple, Cyan, Custom Presets' },
  { label: 'Font Scaling', value: 'Small / Default / Large' },
  { label: 'Motion / Animations', value: 'Standard / Reduced Motion' },
  { label: 'Language & Region', value: 'English · Asia/Manila' },
];

const hybridSettings = [
  { label: 'Availability Toggle', value: 'Open to Collab' },
  { label: 'Role Switcher', value: 'Academic / Serious' },
  { label: 'Verified Academic Badge', value: 'Visible' },
  { label: 'Project Showcase Gallery', value: '3 Pinned Projects' },
];
---

<PlatformLayout title="Settings">
  <section class="flex flex-col gap-8">
    <header class="relative overflow-hidden rounded-[2rem] border border-slate-200 bg-white p-6 shadow-[0_18px_70px_rgba(15,23,42,0.08)] dark:border-white/5 dark:bg-[#252634] dark:shadow-[0_0_40px_rgba(138,43,226,0.1)] md:p-8">
      <div class="pointer-events-none absolute inset-0 bg-[radial-gradient(circle_at_top_left,rgba(138,43,226,0.16),transparent_34%),radial-gradient(circle_at_right,rgba(0,229,255,0.12),transparent_30%)]"></div>
      <div class="relative flex flex-col gap-4 lg:flex-row lg:items-end lg:justify-between">
        <div>
          <p class="font-mono text-[11px] uppercase tracking-[0.28em] text-slate-500 dark:text-slate-400">Settings Dashboard</p>
          <h1 class="mt-3 text-3xl font-semibold tracking-tight text-slate-900 dark:text-white md:text-4xl">
            Account, privacy, notification, and hybrid platform controls
          </h1>
          <p class="mt-3 max-w-2xl text-sm leading-6 text-slate-600 dark:text-slate-300">
            Boilerplate settings surface aligned to your required account controls, privacy rules, notification routing, accessibility options, and the platform-specific hybrid features.
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          <button class="rounded-xl border border-slate-200 bg-slate-100 px-4 py-3 text-sm font-medium text-slate-700 transition-all duration-300 hover:-translate-y-0.5 hover:border-cyan-500/40 hover:text-slate-900 hover:shadow-[0_0_18px_rgba(0,229,255,0.16)] dark:border-white/10 dark:bg-white/5 dark:text-slate-200 dark:hover:text-white">
            Reset Defaults
          </button>
          <button class="rounded-xl border border-purple-500/30 bg-purple-500/10 px-4 py-3 text-sm font-medium text-purple-700 shadow-[0_0_18px_rgba(138,43,226,0.15)] transition-all duration-300 hover:-translate-y-0.5 hover:bg-purple-500/15 dark:text-purple-300">
            Save Preferences
          </button>
        </div>
      </div>
    </header>

    <div class="grid grid-cols-1 gap-6 xl:grid-cols-[minmax(0,1.15fr)_minmax(22rem,0.85fr)]">
      <div class="flex flex-col gap-6">
        <section class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-[0_18px_60px_rgba(15,23,42,0.06)] dark:border-white/5 dark:bg-[#252634] md:p-8">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">Account & Security</p>
              <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">Required access controls</h2>
            </div>
            <span class="rounded-full border border-purple-500/20 bg-purple-500/10 px-3 py-1 font-mono text-[11px] uppercase tracking-[0.22em] text-purple-700 dark:text-purple-300">
              Required
            </span>
          </div>

          <div class="mt-8 flex flex-col gap-4">
            {accountSecurity.map((item) => (
              <article class="flex items-start justify-between gap-4 rounded-[1.5rem] border border-slate-200 bg-slate-50 px-5 py-5 transition-all duration-300 hover:-translate-y-1 hover:border-purple-500/20 hover:shadow-[0_0_24px_rgba(138,43,226,0.08)] dark:border-white/10 dark:bg-white/5 dark:hover:border-purple-500/20">
                <div class="max-w-xl">
                  <h3 class="text-base font-medium text-slate-900 dark:text-white">{item.title}</h3>
                  <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">{item.detail}</p>
                </div>
                <button type="button" aria-pressed="true" class="relative mt-1 h-7 w-14 rounded-full border border-purple-500/30 bg-purple-500/15 shadow-[0_0_16px_rgba(138,43,226,0.12)]">
                  <span class="absolute right-1 top-1 h-5 w-5 rounded-full bg-purple-500"></span>
                </button>
              </article>
            ))}
          </div>
        </section>

        <section class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-[0_18px_60px_rgba(15,23,42,0.06)] dark:border-white/5 dark:bg-[#252634] md:p-8">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">Privacy & Data</p>
              <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">Required visibility and data controls</h2>
            </div>
            <span class="rounded-full border border-purple-500/20 bg-purple-500/10 px-3 py-1 font-mono text-[11px] uppercase tracking-[0.22em] text-purple-700 dark:text-purple-300">
              Required
            </span>
          </div>

          <div class="mt-8 grid grid-cols-1 gap-4 md:grid-cols-2">
            {privacyData.map((item) => (
              <div class="rounded-[1.5rem] border border-slate-200 bg-slate-50 px-4 py-4 dark:border-white/10 dark:bg-white/5">
                <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">{item.label}</p>
                <p class="mt-2 text-sm font-medium text-slate-900 dark:text-white">{item.value}</p>
              </div>
            ))}
          </div>
        </section>

        <section class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-[0_18px_60px_rgba(15,23,42,0.06)] dark:border-white/5 dark:bg-[#252634] md:p-8">
          <div class="flex items-center justify-between gap-4">
            <div>
              <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">Notification Preferences</p>
              <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">Academic and social signal routing</h2>
            </div>
            <span class="rounded-full border border-cyan-500/20 bg-cyan-500/10 px-3 py-1 font-mono text-[11px] uppercase tracking-[0.22em] text-cyan-700 dark:text-cyan-300">
              Recommended
            </span>
          </div>

          <div class="mt-8 flex flex-col gap-4">
            {notifications.map((item) => (
              <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50 px-5 py-5 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-500/20 hover:shadow-[0_0_24px_rgba(0,229,255,0.08)] dark:border-white/10 dark:bg-white/5">
                <h3 class="text-base font-medium text-slate-900 dark:text-white">{item.title}</h3>
                <p class="mt-2 text-sm leading-6 text-slate-600 dark:text-slate-300">{item.detail}</p>
              </article>
            ))}
          </div>
        </section>
      </div>

      <div class="flex flex-col gap-6">
        <section class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-[0_18px_60px_rgba(15,23,42,0.06)] dark:border-white/5 dark:bg-[#252634]">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">Appearance & Accessibility</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">Optional interface adaptation</h2>

          <div class="mt-6 flex flex-col gap-3">
            {appearance.map((item) => (
              <article class="rounded-[1.5rem] border border-slate-200 bg-slate-50 px-4 py-4 dark:border-white/10 dark:bg-white/5">
                <p class="font-mono text-[11px] uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">{item.label}</p>
                <p class="mt-2 text-sm font-medium text-slate-900 dark:text-white">{item.value}</p>
              </article>
            ))}
          </div>
        </section>

        <section class="rounded-[2rem] border border-slate-200 bg-white p-6 shadow-[0_18px_60px_rgba(15,23,42,0.06)] dark:border-white/5 dark:bg-[#252634]">
          <p class="font-mono text-[11px] uppercase tracking-[0.24em] text-slate-500 dark:text-slate-400">Hybrid Features</p>
          <h2 class="mt-2 text-2xl font-semibold tracking-tight text-slate-900 dark:text-white">Platform-specific switches</h2>

          <div class="mt-6 flex flex-col gap-3">
            {hybridSettings.map((item) => (
              <article class="flex items-center justify-between gap-3 rounded-[1.5rem] border border-slate-200 bg-slate-50 px-4 py-4 transition-all duration-300 hover:-translate-y-1 hover:border-cyan-500/30 hover:shadow-[0_0_22px_rgba(0,229,255,0.12)] dark:border-white/10 dark:bg-white/5">
                <div>
                  <p class="text-sm font-medium text-slate-900 dark:text-white">{item.label}</p>
                  <p class="mt-1 font-mono text-[11px] uppercase tracking-[0.2em] text-slate-500 dark:text-slate-400">Configured State</p>
                </div>
                <span class="rounded-full border border-slate-200 bg-white px-3 py-1 font-mono text-[11px] uppercase tracking-[0.2em] text-slate-600 dark:border-white/10 dark:bg-[#1A1A24] dark:text-slate-300">
                  {item.value}
                </span>
              </article>
            ))}
          </div>
        </section>
      </div>
    </div>
  </section>
</PlatformLayout>
