---
// apps/platform/src/pages/index.astro
// Platform Explore Page — Community Hub entry point.
// Layout: 8-col main feed + 4-col sticky right-rail (lg+), stacked on mobile.
import PlatformLayout from '../layouts/PlatformLayout.astro';
import DailyQuestBanner  from '../components/dashboard/DailyQuestBanner.astro';
import CommunityFeed     from '../components/dashboard/CommunityFeed.astro';
import OperativeSnapshot from '../components/dashboard/OperativeSnapshot.astro';
import TrendingQuests    from '../components/dashboard/TrendingQuests.astro';

// ─── MOCK DATA ───────────────────────────────────────────────────
// Replace with a Prisma/Supabase query when auth is wired.
const operative = {
  name:       'Felix',
  level:      42,
  xpBalance:  '12,450',
  streak:     14,
  avatarSeed: 'Felix',
};

const RAIL_LINKS = [
  { href: '#', label: 'Documentation' },
  { href: '#', label: 'Leaderboard'   },
  { href: '#', label: 'GitHub Sync'   },
  { href: '#', label: 'Support'       },
];
---

<PlatformLayout title="Explore" currentPath="/">

  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 xl:gap-12 w-full items-start">

    <!-- ═══════════════════════════════════════════════════════
         MAIN FEED — 8 columns
    ════════════════════════════════════════════════════════════ -->
    <div class="lg:col-span-8 flex flex-col gap-10">

      <!-- Featured Quest of the Day -->
      <section aria-labelledby="featured-heading">
        <div class="flex items-center justify-between mb-4">
          <h2 id="featured-heading" class="font-bold text-base tracking-tight leading-none text-slate-900 dark:text-white">
            Featured
          </h2>
        </div>
        <DailyQuestBanner />
      </section>

      <!-- Global Transmissions Feed -->
      <section aria-labelledby="feed-heading">
        <CommunityFeed />
      </section>

    </div>

    <!-- ═══════════════════════════════════════════════════════
         RIGHT RAIL — 4 columns, sticky on lg+
         On mobile it stacks naturally below the feed.
    ════════════════════════════════════════════════════════════ -->
    <aside class="lg:col-span-4 flex flex-col gap-6 lg:sticky lg:top-24" aria-label="Operative information">

      <OperativeSnapshot {...operative} />

      <TrendingQuests />

      <!-- Meta utility links -->
      <nav class="flex flex-wrap gap-x-4 gap-y-2 px-1" aria-label="Platform utilities">
        {RAIL_LINKS.map(link => (
          <a
            href={link.href}
            class="text-[10px] font-mono text-slate-400 dark:text-slate-500 uppercase tracking-widest hover:text-slate-600 dark:hover:text-slate-300 transition-colors"
          >
            {link.label}
          </a>
        ))}
      </nav>

    </aside>

  </div>

</PlatformLayout>