---
// apps/platform/src/pages/index.astro
import PlatformLayout from '../layouts/PlatformLayout.astro';
import DailyQuestBanner from '../components/dashboard/DailyQuestBanner.astro';
import CommunityFeed from '../components/dashboard/CommunityFeed.astro';
import OperativeSnapshot from '../components/dashboard/OperativeSnapshot.astro';
import TrendingQuests from '../components/dashboard/TrendingQuests.astro';

// --- MOCK DATA --- //
const operativeData = {
  name: "Felix",
  level: 42,
  xpBalance: "12,450",
  streak: 14,
  avatarSeed: "Felix"
};
---

<PlatformLayout title="Explore" currentPath="/">
  
  <div class="grid grid-cols-1 lg:grid-cols-12 gap-8 lg:gap-12 w-full">
    
    <!-- LEFT: Main Feed Column (8 Cols) -->
    <div class="lg:col-span-8 flex flex-col gap-10">
      
      <!-- The Big Daily CTA -->
      <section>
         <div class="flex items-center justify-between mb-4">
            <h2 class="text-white font-bold text-lg tracking-tight leading-none">Featured</h2>
         </div>
         <DailyQuestBanner />
      </section>
      
      <!-- The Social / Global Activity Feed -->
      <section>
         <CommunityFeed />
      </section>

    </div>

    <!-- RIGHT: Personalized Rail (4 Cols) -->
    <aside class="lg:col-span-4 flex flex-col gap-8 h-max sticky top-24">
       
       <OperativeSnapshot {...operativeData} />
       
       <TrendingQuests />

       <!-- Small footer/meta links in the rail -->
       <div class="flex flex-wrap gap-x-4 gap-y-2 px-2 text-[10px] font-mono text-slate-600 uppercase tracking-widest mt-4">
          <a href="#" class="hover:text-slate-400 transition-colors">Documentation</a>
          <a href="#" class="hover:text-slate-400 transition-colors">Leaderboard</a>
          <a href="#" class="hover:text-slate-400 transition-colors">GitHub Sync</a>
          <a href="#" class="hover:text-slate-400 transition-colors">Support</a>
       </div>

    </aside>

  </div>

</PlatformLayout>