---
import '../global.css';
import { PlatformIsland } from '../components/PlatformIsland';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Forge Platform</title>
  </head>
  <body class="bg-[#1A1A24] text-white min-h-screen">
    <header class="w-full fixed top-0 bg-[#252634]/80 backdrop-blur-md border-b border-white/5 p-4 z-50">
      <nav class="max-w-7xl mx-auto flex justify-between items-center">
        <h1 class="text-[#8A2BE2] font-bold text-xl tracking-wider">FORGE PORTAL</h1>
      </nav>
    </header>
    
    <main>
      <PlatformIsland client:load />
    </main>
  </body>
</html>