---
// apps/platform/src/pages/registry.astro
import PlatformLayout from '../layouts/PlatformLayout.astro';
---

<PlatformLayout title="Registry Logs" currentPath="/registry">
  <div class="flex-grow flex items-center justify-center border-2 border-dashed border-slate-200 dark:border-white/5 rounded-[2.5rem] bg-slate-100 dark:bg-white/50 dark:bg-white dark:bg-[#252634]/50 p-24 w-full">
    <div class="text-center flex flex-col items-center gap-4">
      <div class="w-16 h-16 rounded-2xl bg-emerald-500/10 flex items-center justify-center text-emerald-400">
        <svg class="w-8 h-8" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z" /></svg>
      </div>
      <h2 class="text-2xl font-bold tracking-tighter">Attendance & Commits</h2>
      <p class="text-slate-600 dark:text-[#A0A0B0] text-sm max-w-sm">The decentralized log of your physical presence across Code Bearers nodes and your raw PR history.</p>
    </div>
  </div>
</PlatformLayout>
