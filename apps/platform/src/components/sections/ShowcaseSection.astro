---
// ShowcaseSection — SEO-optimised, zero-JS project gallery
---
<section class="max-w-7xl mx-auto px-4 md:px-8 w-full mt-10">
  <div class="flex flex-col gap-4 mb-12 sm:mb-16">
    <h2 class="text-3xl md:text-5xl font-bold tracking-tighter text-slate-900 dark:text-white mb-2">Capstone Outputs.</h2>
    <p class="text-slate-600 dark:text-[#A0A0B0] max-w-2xl text-base md:text-lg leading-relaxed">
      Explore our archive of high-performance tools and UI/UX research. The raw source code of our progress.
    </p>
  </div>

  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-6">
    <!-- Placeholder: No data found -->
    <div class="aspect-square bg-white dark:bg-[#252634] border border-slate-300 dark:border-white/5 border-dashed rounded-[2rem] flex flex-col items-center justify-center text-center p-8 gap-4 group hover:border-cyan-500/50 dark:hover:border-[#00E5FF]/50 hover:bg-slate-50 dark:hover:bg-[#2D2E42] transition-colors cursor-pointer">
      <div class="w-12 h-12 rounded-full bg-slate-50 dark:bg-[#1A1A24] flex items-center justify-center text-slate-400 dark:text-[#5C5C70] group-hover:text-cyan-500 dark:group-hover:text-[#00E5FF] transition-colors border border-transparent group-hover:border-cyan-500/30 dark:group-hover:border-[#00E5FF]/30 group-hover:shadow-[0_0_15px_rgba(138,43,226,0.15)]">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
        </svg>
      </div>
      <span class="font-mono text-[10px] md:text-xs text-slate-500 dark:text-[#5C5C70] uppercase tracking-[0.15em] leading-relaxed group-hover:text-slate-600 dark:group-hover:text-[#A0A0B0]">
        No data found.<br/>Initiate scan.
      </span>
    </div>

    <!-- Placeholder: Connect repo -->
    <div class="aspect-square bg-white dark:bg-[#252634] border border-slate-300 dark:border-white/5 border-dashed rounded-[2rem] flex flex-col items-center justify-center text-center p-8 gap-4 group hover:border-purple-500/50 dark:hover:border-[#8A2BE2]/50 hover:bg-slate-50 dark:hover:bg-[#2D2E42] transition-colors cursor-pointer">
      <div class="w-12 h-12 rounded-full bg-slate-50 dark:bg-[#1A1A24] flex items-center justify-center text-slate-400 dark:text-[#5C5C70] group-hover:text-purple-500 dark:group-hover:text-[#8A2BE2] transition-colors border border-transparent group-hover:border-purple-500/30 dark:group-hover:border-[#8A2BE2]/30 group-hover:shadow-[0_0_15px_rgba(0,229,255,0.15)]">
        <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 4v16m8-8H4" />
        </svg>
      </div>
      <span class="font-mono text-[10px] md:text-xs text-slate-500 dark:text-[#5C5C70] uppercase tracking-[0.15em] leading-relaxed group-hover:text-slate-600 dark:group-hover:text-[#A0A0B0]">
        Connect<br/>Repository.
      </span>
    </div>
  </div>
</section>
