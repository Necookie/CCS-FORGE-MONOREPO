---
// Source link: `components/sections/ArchiveTimeline.astro`

interface TimelineEvent {
  id: string;
  title: string;
  tag: string;
  dateStr: string;
  description: string;
  images: { src: string; alt: string }[];
}

const events: TimelineEvent[] = [
  {
    id: "cb-8812af",
    title: "CodeChum Nationals 2025",
    tag: "[ GROUP STAGE 3 SEMIFINALIST ]",
    dateStr: "EXECUTE: CodeChum_2025_Nationals",
    description: "Competing against the top teams in the nation, the Code Bearers successfully deployed advanced algorithmic strategies. We secured a slot as Group Stage 3 Semifinalists, solidifying our foundation of competitive excellence in the inter-collegiate arena.",
    images: [
      {
        src: "https://res.cloudinary.com/dd6gz4moa/image/upload/v1776407967/bracket_spsocr.jpg",
        alt: "Bracket standing"
      },
      {
        src: "https://res.cloudinary.com/dd6gz4moa/image/upload/v1776407970/Image_z14qwo.jpg",
        alt: "Documentation photo 1"
      },
      {
        src: "https://res.cloudinary.com/dd6gz4moa/image/upload/v1776407967/Image_2_fuf30e.jpg",
        alt: "Documentation photo 2"
      }
    ]
  }
];
---

<section id="archive-timeline" class="max-w-5xl mx-auto px-4 md:px-8 w-full pt-32 pb-24 relative z-10">
  <div class="flex flex-col gap-4 mb-16 md:mb-24 text-center items-center">
    <span class="font-mono text-xs uppercase tracking-[0.15em] text-cyan-600 dark:text-[#00E5FF]">[ SYSTEM.LOG // LEGACY ]</span>
    <h1 class="text-4xl md:text-6xl font-bold tracking-tighter text-slate-900 dark:text-white mb-2">The Archive.</h1>
    <p class="text-slate-600 dark:text-[#A0A0B0] max-w-2xl text-base md:text-lg leading-relaxed">
      A cryptographic trace of the Code Bearers' milestones, deployments, and conquered arenas.
    </p>
  </div>

  <div class="relative w-full overflow-hidden sm:overflow-visible">
    <!-- Center PCB Trace Line (Hidden on tiny mobile, visible sm+) -->
    <div class="absolute left-[39px] sm:left-1/2 sm:-translate-x-1/2 top-0 bottom-0 w-1 bg-gradient-to-b from-purple-500/20 via-cyan-500/20 to-transparent dark:from-[#8A2BE2]/20 dark:via-[#00E5FF]/20 rounded-full z-0"></div>

    <div class="flex flex-col gap-12 sm:gap-24 relative z-10">
      {events.map((event, index) => {
        const isEven = index % 2 === 0;
        return (
          <div class={`flex flex-col sm:flex-row items-stretch sm:items-center w-full gap-6 sm:gap-0 ${isEven ? 'sm:flex-row-reverse' : ''}`}>
            
            <!-- Timeline Center Node -->
            <div class="absolute left-[28px] sm:left-1/2 sm:-translate-x-1/2 w-6 h-6 rounded-full bg-white dark:bg-[#1A1A24] border-2 border-purple-500 dark:border-[#8A2BE2] shadow-[0_0_15px_rgba(138,43,226,0.5)] flex items-center justify-center shrink-0 z-20 mt-8 sm:mt-0">
               <div class="w-1.5 h-1.5 rounded-full bg-purple-500 dark:bg-[#8A2BE2] animate-pulse"></div>
            </div>

            <!-- Empty space for the other half -->
            <div class="hidden sm:block sm:w-1/2"></div>
            
            <!-- Content Card -->
            <div class="w-full sm:w-1/2 pl-24 sm:pl-0 sm:px-12 flex relative group">
               
               <!-- Branch connecting trace -->
               <div class={`hidden sm:block absolute top-[50%] -translate-y-1/2 w-12 h-px bg-purple-500/30 dark:bg-[#8A2BE2]/30 ${isEven ? 'right-0' : 'left-0'}`}></div>

               <!-- The GUI Widget Card -->
               <div class={`w-full bg-white dark:bg-[#252634] p-6 sm:p-8 rounded-[1.5rem] sm:rounded-[2rem] border border-slate-200 dark:border-white/5 shadow-sm dark:shadow-[0_4px_30px_rgba(0,0,0,0.1)] hover:shadow-lg dark:hover:border-purple-500/30 dark:hover:shadow-[0_0_20px_rgba(138,43,226,0.15)] transition-all duration-300 relative overflow-hidden`}>
                 
                 <!-- Ambient decorative glow inside card -->
                 <div class={`absolute top-0 w-32 h-32 bg-purple-500/5 dark:bg-[#8A2BE2]/5 rounded-full blur-2xl pointer-events-none -translate-y-1/2 ${isEven ? '-left-10' : '-right-10'}`}></div>

                 <div class="relative z-10 flex flex-col gap-4">
                   <!-- Meta header -->
                   <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-3 mb-2">
                     <div class="inline-flex max-w-fit px-3 py-1 bg-purple-500/10 dark:bg-[#8A2BE2]/10 rounded-full border border-purple-500/20 dark:border-[#8A2BE2]/20 shadow-sm">
                       <span class="font-mono text-[10px] sm:text-xs uppercase text-purple-600 dark:text-[#8A2BE2] tracking-wider leading-none">{event.tag}</span>
                     </div>
                     <div class="font-mono text-[10px] text-cyan-600 dark:text-[#00E5FF] uppercase tracking-widest">{event.dateStr}</div>
                   </div>

                   <!-- Text content -->
                   <div>
                     <h2 class="text-xl sm:text-2xl font-bold text-slate-900 dark:text-white group-hover:text-purple-600 dark:group-hover:text-[#8A2BE2] transition-colors">{event.title}</h2>
                     <div class="inline-block font-mono text-[10px] text-slate-400 dark:text-[#5C5C70] mt-1 uppercase tracking-[0.2em]">ID: {event.id}</div>
                   </div>

                   <p class="text-slate-600 dark:text-[#A0A0B0] text-sm leading-relaxed mt-2">
                     {event.description}
                   </p>

                   <!-- Image Attachments (Fixed distortion & sizing) -->
                   {event.images.length > 0 && (
                     <div class="mt-4 pt-4 border-t border-slate-100 dark:border-white/5">
                       <span class="font-mono text-[10px] text-slate-400 dark:text-[#5C5C70] uppercase tracking-widest mb-3 block">Attachments // {event.images.length}</span>
                       <div class="flex flex-wrap gap-3">
                         {event.images.map((img) => (
                           <a href={img.src} target="_blank" rel="noopener noreferrer" title="View Full Image" class="relative group/img block h-24 sm:h-28 rounded-xl overflow-hidden border border-slate-200 dark:border-white/10 bg-slate-50 dark:bg-[#1A1A24] cursor-pointer hover:border-cyan-500/50 dark:hover:border-[#00E5FF]/50 transition-all shadow-sm">
                              <!-- object-contain ensures NO distortion -->
                              <img src={img.src} alt={img.alt} class="h-full w-auto object-contain opacity-90 transition-all duration-300 group-hover/img:scale-105 group-hover/img:opacity-100" loading="lazy" />
                           </a>
                         ))}
                       </div>
                     </div>
                   )}
                 </div>
               </div>
            </div>
          </div>
        );
      })}
    </div>
  </div>
</section>
