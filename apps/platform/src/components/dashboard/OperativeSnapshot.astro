---
// apps/platform/src/components/dashboard/OperativeSnapshot.astro

interface Props {
  name: string;
  level: number;
  xpBalance: string;
  streak: number;
  avatarSeed: string;
}

const { name, level, xpBalance, streak, avatarSeed } = Astro.props;
---

<div class="rounded-[1.5rem] bg-[#252634] border border-white/5 p-5 flex flex-col gap-5 relative overflow-hidden group">
   <!-- Subtle Glow -->
   <div class="absolute top-0 right-0 w-32 h-32 bg-purple-500/10 rounded-full blur-[40px] -translate-y-1/2 translate-x-1/2 pointer-events-none"></div>
   
   <!-- Header: Avatar & Level -->
   <div class="flex items-center gap-4 relative z-10">
      <div class="w-16 h-16 rounded-[1rem] bg-[#1A1A24] border border-purple-500/30 flex items-center justify-center p-1 relative shadow-[0_0_15px_rgba(138,43,226,0.15)] group-hover:border-purple-500/60 transition-colors">
         <img src={`https://api.dicebear.com/9.x/avataaars/svg?seed=${avatarSeed}`} alt={name} class="w-full h-full object-contain" />
         <!-- Level float -->
         <div class="absolute -bottom-1.5 -right-1.5 px-2 py-0.5 bg-purple-600 rounded-lg text-[9px] font-bold tracking-widest border border-white/20 shadow-sm leading-none flex items-center justify-center text-white">
            LVL {level}
         </div>
      </div>

      <div class="flex flex-col">
         <h2 class="font-bold text-lg leading-tight">{name}</h2>
         <span class="text-xs text-slate-400">Class 3 Architect</span>
      </div>
   </div>

   <!-- Stats Grid -->
   <div class="grid grid-cols-2 gap-3 relative z-10">
      <!-- XP -->
      <div class="flex flex-col p-3 rounded-xl bg-[#1A1A24]/70 border border-white/5">
         <span class="text-[9px] uppercase font-bold text-slate-500 tracking-widest mb-1">XP Balance</span>
         <span class="text-sm font-mono text-purple-400">{xpBalance}</span>
      </div>
      <!-- Streak -->
      <div class="flex flex-col p-3 rounded-xl bg-[#1A1A24]/70 border border-white/5">
         <span class="text-[9px] uppercase font-bold text-slate-500 tracking-widest mb-1 flex items-center gap-1">
           <svg class="w-3 h-3 text-orange-500" fill="currentColor" viewBox="0 0 20 20"><path fill-rule="evenodd" d="M12.395 2.553a1 1 0 00-1.45-.385c-.345.23-.614.558-.822.88-.214.33-.403.713-.57 1.116-.334.804-.614 1.768-.84 2.734a31.365 31.365 0 00-.613 3.58 2.64 2.64 0 01-.945-1.067c-.328-.68-.398-1.534-.398-2.654A1 1 0 005.05 6.05 6.981 6.981 0 003 11a7 7 0 1011.95-4.95c-.592-.591-.98-.985-1.348-1.467-.363-.476-.724-1.063-1.207-2.03zM12.12 15.12A3 3 0 017 13s.879.5 2.5.5c0-1 .5-4 1.25-4.5.5 1 .786 1.293 1.371 1.879A2.99 2.99 0 0113 13a2.99 2.99 0 01-.879 2.121z" clip-rule="evenodd" /></svg>
           Day Streak
         </span>
         <span class="text-sm font-mono text-orange-400">{streak}</span>
      </div>
   </div>

   <!-- Action CTA -->
   <button class="w-full py-2.5 rounded-xl bg-purple-600/10 text-purple-400 font-bold text-xs uppercase tracking-widest border border-purple-500/30 hover:bg-purple-600 hover:text-white transition-all shadow-[0_0_10px_rgba(138,43,226,0.1)] relative z-10 hover:-translate-y-0.5">
      View Master Profile
   </button>
</div>
