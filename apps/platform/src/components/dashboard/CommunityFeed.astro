---
// apps/platform/src/components/dashboard/CommunityFeed.astro

export interface SocialLog {
  id: string;
  avatarSeed: string;
  name: string;
  action: string;
  target: string;
  time: string;
  type: 'achievement' | 'commit' | 'discussion';
  meta?: string;
}

const mockFeeds: SocialLog[] = [
  {
    id: 'f-1',
    avatarSeed: 'Alex',
    name: 'Operative Alex',
    action: 'secured the badge',
    target: 'Algorithm Master',
    time: '2h ago',
    type: 'achievement'
  },
  {
    id: 'f-2',
    avatarSeed: 'Sarah',
    name: 'Sarah // UI Lead',
    action: 'pushed 3 commits to',
    target: 'core/glow-engine',
    time: '4h ago',
    type: 'commit',
    meta: '#cb-8910fa'
  },
  {
    id: 'f-3',
    avatarSeed: 'Marcus',
    name: 'Marcus // Data',
    action: 'completed the quest',
    target: 'Prisma DB Migration',
    time: '6h ago',
    type: 'achievement',
    meta: '+ 800 XP'
  },
  {
    id: 'f-4',
    avatarSeed: 'Elena',
    name: 'Elena',
    action: 'started a discussion on',
    target: 'Optimizing Astro Islands',
    time: '12h ago',
    type: 'discussion'
  }
];

// Helper to determine tailwind accent colors based on social type
const getTypeColor = (type: string) => {
  if (type === 'achievement') return 'text-purple-400 bg-purple-500/10 ring-purple-500/30';
  if (type === 'commit') return 'text-cyan-400 bg-cyan-500/10 ring-cyan-500/30';
  return 'text-emerald-400 bg-emerald-500/10 ring-emerald-500/30';
};
---

<div class="flex flex-col gap-6 w-full">
  
  <div class="flex items-center gap-4 border-b border-white/5 pb-4">
     <h2 class="text-xl font-bold tracking-tight text-white leading-none">Global Transmissions</h2>
     <div class="px-2 py-0.5 rounded-md bg-white/5 border border-white/10 text-[10px] font-mono text-slate-400 uppercase leading-none">Live Feed</div>
  </div>

  <div class="flex flex-col gap-4 relative">
     <!-- Vertical timeline trace -->
     <div class="absolute left-[19px] top-4 bottom-4 w-px bg-white/5 z-0 hidden sm:block"></div>
     
     {mockFeeds.map((feed) => {
        const typeStyle = getTypeColor(feed.type);
        return (
          <div class="relative z-10 flex gap-4 sm:gap-6 group">
             
             <!-- Avatar -->
             <div class="w-10 h-10 rounded-[1rem] bg-[#252634] border border-white/10 shrink-0 flex items-center justify-center overflow-hidden hover:border-white/30 transition-colors cursor-pointer z-10 shadow-sm relative">
                <img src={`https://api.dicebear.com/9.x/avataaars/svg?seed=${feed.avatarSeed}`} alt={feed.name} class="w-full h-full object-contain" />
             </div>

             <!-- Content Card -->
             <div class="flex-grow rounded-[1.5rem] bg-transparent sm:bg-[#252634]/50 sm:group-hover:bg-[#252634] sm:border sm:border-white/5 sm:group-hover:border-white/10 p-1 sm:p-4 transition-all duration-300">
                <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-2">
                   
                   <div class="text-sm text-slate-300 leading-tight">
                      <span class="font-bold text-white hover:text-purple-400 cursor-pointer transition-colors inline-block mr-1">{feed.name}</span>
                      <span class="text-slate-500 mr-1">{feed.action}</span>
                      <span class="font-bold text-white hover:text-cyan-400 cursor-pointer transition-colors">{feed.target}</span>
                   </div>
                   
                   <span class="text-[10px] uppercase font-mono text-slate-600 tracking-widest shrink-0">{feed.time}</span>
                </div>

                {feed.meta && (
                  <div class="mt-3 inline-flex items-center gap-2">
                     <span class={`px-2 py-1 rounded-lg text-[10px] font-mono uppercase tracking-widest leading-none ring-1 border border-transparent ${typeStyle}`}>
                       {feed.meta}
                     </span>
                  </div>
                )}
             </div>

          </div>
        )
     })}
     
     <button class="w-full py-4 mt-2 text-xs font-bold uppercase tracking-widest text-slate-500 hover:text-slate-300 transition-colors border-2 border-dashed border-white/5 rounded-[1.5rem] hover:border-white/10 bg-transparent">
        Load Older Transmissions
     </button>
  </div>
</div>
