---
// apps/platform/src/components/dashboard/CommunityFeed.astro
// Renders the global social activity timeline for the Explore page.

interface SocialLog {
  id: string;
  avatarSeed: string;
  name: string;
  action: string;
  target: string;
  time: string;
  type: 'achievement' | 'commit' | 'discussion';
  meta?: string;
}

// O(1) lookup map — constant time per entry, no repeated string comparisons
const TYPE_STYLE_MAP: Record<SocialLog['type'], string> = {
  achievement: 'text-purple-600 dark:text-purple-400 bg-purple-500/10 ring-1 ring-purple-500/20',
  commit:      'text-cyan-600   dark:text-cyan-400   bg-cyan-500/10   ring-1 ring-cyan-500/20',
  discussion:  'text-emerald-600 dark:text-emerald-400 bg-emerald-500/10 ring-1 ring-emerald-500/20',
};

const FEEDS: SocialLog[] = [
  {
    id: 'f-1',
    avatarSeed: 'Alex',
    name: 'Operative Alex',
    action: 'secured the badge',
    target: 'Algorithm Master',
    time: '2h ago',
    type: 'achievement',
  },
  {
    id: 'f-2',
    avatarSeed: 'Sarah',
    name: 'Sarah // UI Lead',
    action: 'pushed 3 commits to',
    target: 'core/glow-engine',
    time: '4h ago',
    type: 'commit',
    meta: '#cb-8910fa',
  },
  {
    id: 'f-3',
    avatarSeed: 'Marcus',
    name: 'Marcus // Data',
    action: 'completed the quest',
    target: 'Prisma DB Migration',
    time: '6h ago',
    type: 'achievement',
    meta: '+ 800 XP',
  },
  {
    id: 'f-4',
    avatarSeed: 'Elena',
    name: 'Elena',
    action: 'started a discussion on',
    target: 'Optimizing Astro Islands',
    time: '12h ago',
    type: 'discussion',
  },
];
---

<div class="flex flex-col gap-6 w-full">

  <!-- Section Header -->
  <div class="flex items-center gap-4 border-b border-slate-200 dark:border-white/5 pb-4">
    <h2 class="text-xl font-bold tracking-tight leading-none">Global Transmissions</h2>
    <div class="px-2 py-0.5 rounded-md bg-slate-100 dark:bg-white/5 border border-slate-200 dark:border-white/10 text-[10px] font-mono text-slate-500 dark:text-slate-400 uppercase leading-none">
      Live Feed
    </div>
  </div>

  <!-- Feed List -->
  <div class="flex flex-col gap-4 relative">

    <!-- Vertical connector line (sm+) -->
    <div class="absolute left-[19px] top-5 bottom-5 w-px bg-slate-200 dark:bg-white/5 hidden sm:block pointer-events-none" aria-hidden="true"></div>

    {FEEDS.map((feed) => {
      const metaStyle = TYPE_STYLE_MAP[feed.type];
      return (
        <article class="relative z-10 flex gap-4 sm:gap-5 group" aria-label={`Activity from ${feed.name}`}>

          <!-- Avatar -->
          <div class="w-10 h-10 rounded-xl bg-white dark:bg-[#252634] border border-slate-200 dark:border-white/10 shrink-0 overflow-hidden group-hover:border-slate-300 dark:group-hover:border-white/20 transition-colors z-10 shadow-sm">
            <img
              src={`https://api.dicebear.com/9.x/avataaars/svg?seed=${feed.avatarSeed}`}
              alt={`${feed.name} avatar`}
              class="w-full h-full object-contain"
              loading="lazy"
            />
          </div>

          <!-- Content Card -->
          <div class="flex-grow min-w-0 rounded-2xl bg-white dark:bg-[#252634]/50 group-hover:bg-slate-50 dark:group-hover:bg-[#252634] border border-slate-200 dark:border-white/5 group-hover:border-slate-300 dark:group-hover:border-white/10 p-4 transition-all duration-200">

            <!-- Actor + Action -->
            <div class="flex flex-col sm:flex-row sm:items-center justify-between gap-1">
              <p class="text-sm text-slate-600 dark:text-slate-300 leading-snug">
                <button type="button" class="font-bold text-slate-900 dark:text-white hover:text-purple-600 dark:hover:text-purple-400 transition-colors mr-1 inline-block">
                  {feed.name}
                </button>
                <span class="mr-1">{feed.action}</span>
                <button type="button" class="font-semibold text-slate-900 dark:text-white hover:text-cyan-600 dark:hover:text-cyan-400 transition-colors">
                  {feed.target}
                </button>
              </p>
              <time class="text-[10px] uppercase font-mono text-slate-400 dark:text-slate-500 tracking-widest shrink-0">
                {feed.time}
              </time>
            </div>

            <!-- Meta Tag (if present) -->
            {feed.meta && (
              <div class="mt-2.5">
                <span class={`inline-flex items-center px-2 py-0.5 rounded-lg text-[10px] font-mono uppercase tracking-widest leading-none ${metaStyle}`}>
                  {feed.meta}
                </span>
              </div>
            )}

          </div>
        </article>
      );
    })}

    <!-- Load more -->
    <button
      type="button"
      class="w-full py-4 mt-2 text-xs font-bold uppercase tracking-widest text-slate-400 hover:text-slate-600 dark:hover:text-slate-300 transition-colors border-2 border-dashed border-slate-200 dark:border-white/10 hover:border-slate-300 dark:hover:border-white/20 rounded-2xl bg-transparent"
    >
      Load Older Transmissions
    </button>

  </div>

</div>
